# ──────────────────────────────────────────────────────────────────────
# sentry-tool – environment configuration
# Copy this file to .env and fill in your values.
# .env is read from the working directory at startup.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────

# Your Sentry organisation slug.
# Found in Settings → General → Organization Slug, or in any Sentry URL:
# https://sentry.io/organizations/<SENTRY_ORG>/
SENTRY_ORG=my-org-slug

# Sentry auth token with at least the following scopes:
#   event:read   issue:read
# Generate one at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
